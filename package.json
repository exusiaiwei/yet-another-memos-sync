{
	"name": "yet-another-memos-sync",
	"version": "1.6.1",
	"description": "Enhanced Obsidian plugin for syncing Memos with emoji timeline, List Callout format support and improved deletion detection",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint main.ts src",
		"lint:fix": "eslint --fix main.ts src",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release-notes": "node generate-release-notes.js"
	},
	"keywords": [
		"obsidian",
		"memos",
		"sync",
		"daily-notes",
		"emoji",
		"timeline"
	],
	"author": "exusiaiwei",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"esbuild": "0.17.3",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"moment": "^2.29.4",
		"obsidian-daily-notes-interface": "^0.9.4"
	}
}
